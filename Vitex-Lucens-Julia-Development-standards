\section{Git Workflow}
\begin{itemize}
    \item The main branch should never be pushed to!!! Or worked on!!
    \item Check out a new branch. \textit{Branches should be comprehensively named in snake\_case (Julia convention).}
    \item Work in your branch.
    \item Squash commits. \textit{See section on Squash for merge.}
    \item Push your branch and request a review before merging.
    \item Merge your branch into main.
\end{itemize}

\subsection{Squash for Merge}

\noindent\large \textbf{WARNING: THIS CAN PERMANENTLY DELETE YOUR WORK}
\normalsize

\vspace{0.5em}
\begin{itemize}
    \item \textbf{git branch} \textit{Check you are in the correct branch}
    \item \textbf{git log}
    \item Copy the \textbf{hash} of the last commit in your branch before your first commit in this branch. This should have been the last commit in the main branch when you checked out and started working on this branch.
    \item \textbf{git reset --soft \textit{\textless{}\# number copied from previous step\textgreater{}}}
    \item \textbf{git status} \textit{You should see every change made in this branch staged for commit.}
    \item \textbf{git commit}
    \item Delete the comments that are there and enter your \textbf{Final Commit}. \textit{See Final commit style section for styling}
    \item \textbf{git status} \textit{Check that all staged changes have been committed}
    \item \textbf{git log} \textit{Check that the commit history looks correct}
    \item \textbf{git branch} \textit{Check that you are on the right branch}
    \item \textbf{git push --force} \textit{Overwrite the branch history on remote}
\end{itemize}

