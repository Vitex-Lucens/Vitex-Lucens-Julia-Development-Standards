\subsection{Final Commit Style}

\noindent\textbf{Format:}

\begin{flushleft}
Title: This is a short description of what was done in this branch.\\

\vspace{1em}
\text{Description:}\\
\hspace*{2em}- Change one.\\
\hspace*{2em}- Change two.\\
\hspace*{2em}- etc\\

\vspace{1em}
\text{Testing:}\\
\hspace*{2em}- Test one.\\
\hspace*{2em}- Test two.\\
\hspace*{2em}- etc\\
\end{flushleft}

\subsection{Common Git Commands}
\begin{itemize}
    \item \textbf{git status} \textit{Shows your commit staging status}
    \item \textbf{git branch} \textit{Shows you all branches in the repo and your current branch}
    \item \textbf{git checkout -b \textless{}\textit{new\_branch\_name}\textgreater{}} \textit{Creates a new branch from your current branch}
    \item \textbf{git checkout \textless{}\textit{branch\_name}\textgreater{}} \textit{Switches to a different branch}
    \item \textbf{git checkout \textless{}\textit{other\_branch\_name}\textgreater{} -- path/to/your/file} \textit{Pulls a file from another branch into your branch}
    \item \textbf{git log} \textit{Shows your git commit history}
    \item \textbf{git add \textless{}\textit{files to add}\textgreater{}} \textit{Adds the changed files to the staging area}
    \item \textbf{git commit -m \textless{}"Commit message"\textgreater{}} \textit{Commits changes in the staging area}
    \item \textbf{git pull} \textit{Pulls updates from the remote onto your local branch}
    \item \textbf{git push} \textit{Pushes updates from your local branch to the remote}
    \item \textbf{git push --force} \textit{Overwrites the remote branch with your local branch}
    \item \textbf{git stash} \textit{Stashes the changes in your working directory}
    \item \textbf{git stash pop} \textit{Unstashes your last stashed changes}
    \item \textbf{git reset --hard \textless{}\textit{old commit \#}\textgreater{}} \textit{Deletes all changes and commits after the chosen hash}
    \item \textbf{git reset --soft \textless{}\textit{old commit \#}\textgreater{}} \textit{Deletes commits after the chosen hash}
\end{itemize}

