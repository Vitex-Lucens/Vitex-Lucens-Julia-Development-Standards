\section{File Naming Conventions}

\subsection{General Rules}
\begin{itemize}
    \item Use \texttt{snake\_case.jl} for all files.
    \item One function definition per file.
    \item Module files use \texttt{CamelCase.jl} matching the module name.
    \item File name should match the function name exactly.
    \item Folder names use \texttt{snake\_case}.
\end{itemize}

\subsection{Examples}
\begin{verbatim}
# Main module file
DesignAirship.jl

# Function files (file name matches function name exactly)
get_design_parameters_fnc.jl     # Contains: get_design_parameters_fnc()
example_airship_parameters_fnc.jl # Contains: example_airship_parameters_fnc()
motor_placement_fnc.jl           # Contains: motor_placement_fnc()

# Struct files (file name matches struct name)
designParameters.jl               # Contains: DesignParameters struct
vehicleConfig.jl                  # Contains: VehicleConfig struct

# Folder structure
design_parameters/              # Folder: snake_case
utilities/                      # Folder: snake_case
\end{verbatim}

